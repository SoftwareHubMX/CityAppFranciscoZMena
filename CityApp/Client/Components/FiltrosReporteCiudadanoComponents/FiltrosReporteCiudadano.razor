<div class="content_filtros">
    @if (idRol != 8)
    {
        <div class="content_relative">
            <select value="@idTipoReporteCiudadano" class="from-control input_form" @onchange="SelectIdTipoReporteCiudadano">
                <option value="0">Tipo de reporte...</option>
                @foreach (var tipo in TiposReportesCiudadanos)
                {
                    <option value="@tipo.IdTipoReporteCiudadano">@tipo.TipoReporte</option>
                }
            </select>
            @if (idTipoReporteCiudadanoError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[idTipoReporteCiudadanoError]</p>
                </div>
            }
        </div>
    }
    <div class="content_relative">
        <select value="@idEstausReporte" class="from-control input_form" @onchange="SelectIdEstausReporte">
            <option value="0">Estatus del reporte...</option>
            @foreach (var estatus in estatusReporteCiudadanos)
            {
                <option value="@estatus.IdEstatusReporteCiudadano">@estatus.Estatus</option>
            }
        </select>
        @if (idEstausReporteError != "")
        {
            <div class="alert_input">
                <p class="text_alert">@ViewString.Keys[idEstausReporteError]</p>
            </div>
        }
    </div>
    <div class="content_filtro_option">
        <div class="content_buttons_sections">
            <h2 class="label_section @section4" @onclick="(() => CambioSection2(0))">@ViewString.Keys["NumeroConcurrencia"]</h2>
            <h2 class="label_section @section5" @onclick="(() => CambioSection2(1))">@ViewString.Keys["RangoConcurrencia"]</h2>
        </div>
        <div class="content_carrusel @carrusel4">
            <div class="content_relative">
                <input type="text" class="input_form" placeholder="@ViewString.Keys["NumeroConcurrencia"]" value="@concurrencia" @onchange="TxtConcurrencia" />
                @if (concurrenciaError != "")
                {
                    <div class="alert_input">
                        <p class="text_alert">@ViewString.Keys[concurrenciaError]</p>
                    </div>
                }
            </div>
        </div>
        <div class="content_carrusel @carrusel5">
            <div class="content_relative">
                <input type="text" class="input_form" placeholder="@ViewString.Keys["MinConcurrencia"]" value="@minConcurrencia" @onchange="TxtMinConcurrencia" />
                @if (minConcurrenciaError != "")
                {
                    <div class="alert_input">
                        <p class="text_alert">@ViewString.Keys[minConcurrenciaError]</p>
                    </div>
                }
            </div>
            <div class="content_relative">
                <input type="text" class="input_form" placeholder="@ViewString.Keys["MaxConcurrencia"]" value="@maxConcurrencia" @onchange="TxtMaxConcurrencia" />
                @if (maxConcurrenciaError != "")
                {
                    <div class="alert_input">
                        <p class="text_alert">@ViewString.Keys[maxConcurrenciaError]</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="content_relative">
        <input type="text" class="input_form" placeholder="@ViewString.Keys["Localidad"]" value="@localidad" @onchange="TxtLocalidad" />
        @if (localidadError != "")
        {
            <div class="alert_input">
                <p class="text_alert">@ViewString.Keys[localidadError]</p>
            </div>
        }
    </div>
    <div class="content_relative">
        <input type="text" class="input_form" placeholder="@ViewString.Keys["Colonia"]" value="@colonia" @onchange="TxtColonia" />
        @if (coloniaError != "")
        {
            <div class="alert_input">
                <p class="text_alert">@ViewString.Keys[coloniaError]</p>
            </div>
        }
    </div>
    <div class="content_relative">
        <input type="text" class="input_form" placeholder="@ViewString.Keys["codigoPostal"]" value="@codigoPostal" @onchange="TxtCodigoPostal" />
        @if (codigoPostalError != "")
        {
            <div class="alert_input">
                <p class="text_alert">@ViewString.Keys[codigoPostalError]</p>
            </div>
        }
    </div>

    <div class="content_relative">
        <input type="text" class="input_form" placeholder="@ViewString.Keys["Id"]" value="@idReporte" @onchange="TxtIdReporte" />
        @if (idReporteError != "")
        {
            <div class="alert_input">
                <p class="text_alert">@ViewString.Keys[idReporteError]</p>
            </div>
        }
    </div>
     <div class="content_relative">
        <button class="button_sumit" @onclick="limpiarFiltro">
            <span>Limpiar</span>
        </button>
    </div>
   @* <div class="content_relative">
        <button class="button_sumit" @onclick="DescargarPlantilla">
            <span>Descargar ecxel</span>
        </button>
    </div>*@
    <div class="content_filtro_option span_2">
    <div class="content_buttons_sections">
        <h2 class="label_section @section1" @onclick="(() => CambioSection(0))">@ViewString.Keys["FechaPublicacion"]</h2>
        <h2 class="label_section @section2" @onclick="(() => CambioSection(1))">@ViewString.Keys["RangoFecha"]</h2>
        <h2 class="label_section @section3" @onclick="(() => CambioSection(2))">@ViewString.Keys["FechaEspecifica"]</h2>
    </div>
    <div class="content_carrusel @carrusel1">
        <div class="content_relative">
            <input type="date" class="input_form" value="@fechaFija.ToString("yyyy-MM-dd")" @onchange="TxtFechaFija" />
            @if (fechaFijaError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[fechaFijaError]</p>
                </div>
            }
        </div>
    </div>
    <div class="content_carrusel @carrusel2">
        <div class="content_relative">
            <input type="date" class="input_form" value="@fechaInicio.ToString("yyyy-MM-dd")" @onchange="TxtFechaInicio" />
            @if (fechaInicioError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[fechaInicioError]</p>
                </div>
            }
        </div>
        <div class="content_relative">
            <input type="date" class="input_form" value="@fechaFin.ToString("yyyy-MM-dd")" @onchange="TxtFechaFin" />
            @if (fechaFinError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[fechaFinError]</p>
                </div>
            }
        </div>
    </div>
    <div class="content_carrusel @carrusel3">
        <div class="content_relative">
            <select value="@year" class="from-control input_form" @onchange="SelectYear">
                <option value="0">Seleccione...</option>
                @for (int i = 2022; i <= DateTime.UtcNow.AddHours(-6).Year; i++)
                {
                    <option value="@i">@i</option>
                }
            </select>
            @if (yearError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[yearError]</p>
                </div>
            }
        </div>
        <div class="content_relative">
            <select value="@month" class="from-control input_form" @onchange="SelectMonth">
                <option value="0">Seleccione...</option>
                <option value="1">Enero</option>
                <option value="2">Febrero</option>
                <option value="3">Marzo</option>
                <option value="4">Abril</option>
                <option value="5">Mayo</option>
                <option value="6">Junio</option>
                <option value="7">Julio</option>
                <option value="8">Agosto</option>
                <option value="9">Septiembre</option>
                <option value="10">Octubre</option>
                <option value="11">Noviembre</option>
                <option value="12">Diciembre</option>
            </select>
            @if (monthError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[monthError]</p>
                </div>
            }
        </div>
    </div>
</div>

</div>

