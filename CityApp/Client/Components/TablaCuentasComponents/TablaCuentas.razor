<div class="content_table">
    <div class="content_title">
        <h2 class="title">@ViewString.Keys["Cuentas"]</h2>
        <div class="btn_cirquel" @onclick="DescargarTodasLasCuentasExcel">
            <i class="fa-solid fa-file-excel"></i>
            <span class="tooltip">Descargar Excel</span>
        </div>
    </div>
    <div class="content_filtros">
        <div class="content_relative">
            <select value="@idRol" class="from-control input_form" @onchange="TxtIdRol">
                <option value="0">@ViewString.Keys["TipoRol"]...</option>
                @for (int i = 0; i < Roles.Count; i++)
                {
                    <option value="@Roles[i].IdRol">@Roles[i].NombreRol</option>
                }
            </select>
            @if(idRolError != "")
            {
                <div class="alert_input">
                    <p class="text_alert">@ViewString.Keys[idRolError]</p>
                </div>
            }
        </div>
        <button class="button_sumit" @onclick="limpiarFiltro">
            <span>Limpiar</span>
        </button>
    </div>
    <div class="content_grid_tabla">
        <div class="content_grid_tabla_header">           
            <div class="col_grid displa_flex">
                <span>Id</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Fecha Registro</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Usuario</span>
            </div>            
            <div class="col_grid displa_flex">
                <span>Rol</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Estatus cuenta</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Nombre</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Teléfono</span>
            </div>
            <div class="col_grid displa_flex">
                <span>Email</span>
            </div>
            @*<div class="col_grid">
                <span>Acciones</span>
            </div>*@
        </div>
        @if (banderaLoader)
        {
            @if (Cuentas != null)
            {
                @if (Cuentas.Count > 0)
                {
                    <div class="content_grid_tabla_boddy">
                        @foreach (var cuentas in Cuentas)
                        {
                            <div class="col_grid">
                                <p class="txt_plano">@cuentas.IdCuenta</p>
                            </div>
                            <div class="col_grid">
                                <p class="txt_plano">@cuentas.FechaRegistro.ToString("dd/MM/yyyy HH:mm:ss")</p>
                            </div>
                            <div class="col_grid">
                                <p class="txt_plano">@cuentas.NombreUsuario</p>
                            </div>
                            <div class="col_grid">
                                @if (cuentas.Rol != null)
                                {
                                    <p class="txt_plano">@cuentas.Rol.NombreRol </p>
                                }
                                else
                                {
                                    <p class="txt_plano">----</p>
                                }
                            </div>
                            <div class="col_grid">
                                <p class="txt_plano">@((cuentas.EstatusActivo) ? "Activo" : "Desactivado")</p>
                            </div>
                            <div class="col_grid">
                                @if (cuentas.Usuario != null)
                                {
                                    <p class="txt_plano">
                                        @cuentas.Usuario.Nombre
                                        @cuentas.Usuario.Apellidos
                                    </p>
                                }
                                else
                                {
                                    <p class="txt_plano">----</p>
                                }
                            </div>                            
                            <div class="col_grid">
                                @if (cuentas.Usuario != null)
                                {
                                    <p class="txt_plano">@cuentas.Usuario.Telefono</p>
                                }
                                else
                                {
                                    <p class="txt_plano">----</p>
                                }
                            </div>
                            <div class="col_grid">
                                @if (cuentas.Contacto != null)
                                {
                                    <p class="txt_plano">@cuentas.Contacto.Correo</p>
                                }
                                else
                                {
                                    <p class="txt_plano">----</p>
                                }
                            </div>
                           @* <div class="col_grid">
                                <div class="content_flex">
                                    <button class="btn_edit" @onclick="(() => IrEditarSecretaria(secretaria.IdSecretaria))">
                                        <i class="far fa-edit"></i>
                                        <span>Editar</span>
                                    </button>
                                    <button class="btn_delete" @onclick="(() => EliminarSecretaria(secretaria.IdSecretaria))">
                                        <i class="far fa-trash-alt"></i>
                                        <span>Eliminar</span>
                                    </button>
                                </div>
                            </div>*@
                        }
                    </div>
                    <div class="content_paginado">
                        @foreach (int i in paginas)
                        {
                            <div class="pagina" @onclick="(() => CambiarPaginaActual(i))">
                                @if (i == paginaActual)
                                {
                                    <span class="selected">@i</span>
                                }
                                else
                                {
                                    <span>@i</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    @if (alerta != "")
                    {
                        <h2 class="no_data">No hay Cuentas</h2>
                    }
                    else
                    {
                        <div class="loader"></div>
                    }
                }
            }
            else
            {
                @if (alerta != "")
                {
                    <h2 class="no_data">No hay Cuentas</h2>
                }
                else
                {
                    <h2 class="no_data">@alerta</h2>
                }
            }
        }
        else
        {
            <div class="loader"></div>
        }
    </div>
</div>

@if (alertaDescarga != "")
{
    @if (alertaDescarga == "Exito")
    {
        <div class="content__alerta -exito">
            <span>Descarga exitosa</span>
        </div>
    }
    else
    {
        <div class="content__alerta -error">
            <span>@alertaDescarga</span>
        </div>
    }
}
