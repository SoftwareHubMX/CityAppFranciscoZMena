<div class="content_table">
    <div class="content_title">
        <h2 class="title">@ViewString.Keys["Patrulla"]</h2>
        <div class="btn_cirquel" @onclick="IrNuevaPatrulla">
            <i class="fas fa-plus"></i>
        </div>
    </div>
    <div class="content_filtros">
        <div class="content_relative">
            <input type="text" class="input_form" placeholder="@ViewString.Keys["Placa"]" value="@placa" @onchange="TxtPlaca"/>
            @if (placaError != "")
            {
                    <div class="alert_input">
                        <p class="text_alert">@ViewString.Keys[placaError]</p>
                    </div>
            }
        </div>
        <div class="content_relative">
            <input type="text" class="input_form" placeholder="@ViewString.Keys["NumeroEco"]" value="@numero" @onchange="TxtNumero" />
            @if (numeroError != "")
            {
                    <div class="alert_input">
                        <p class="text_alert">@ViewString.Keys[numeroError]</p>
                    </div>
            }
        </div>
        <button class="button_sumit" @onclick="limpiarFiltro">
            <span>Limpiar</span>
        </button>
    </div>
    <div class="content_grid_tabla">
        <div class="content_grid_tabla_header">
            <div class="col_grid displa_flex" @onclick="(() => CambioOrden(1))">
                <span>ID</span>
                @if (FiltroPatrullas.Orden == 1)
                {
                        <i class="fas fa-sort-amount-up-alt"></i>
                }
                else
                {
                        <i class="fas fa-sort-amount-down-alt"></i>
                }
            </div>
            <div class="col_grid displa_flex" @onclick="(() => CambioOrden(2))">
                <span>Placa</span>
                @if (FiltroPatrullas.Orden == 3)
                {
                        <i class="fas fa-sort-amount-up-alt"></i>
                }
                else
                {
                        <i class="fas fa-sort-amount-down-alt"></i>
                }
            </div>
            <div class="col_grid displa_flex" @onclick="(() => CambioOrden(3))">
                <span>Número Economico</span>
                @if (FiltroPatrullas.Orden == 5)
                {
                        <i class="fas fa-sort-amount-up-alt"></i>
                }
                else
                {
                        <i class="fas fa-sort-amount-down-alt"></i>
                }
            </div>
            <div class="col_grid">
                <span>Acciones</span>
            </div>
        </div>
        @if (banderaLoader)
        {
            @if (Patrullas != null)
            {
                @if (Patrullas.Count > 0)
                {
                    <div class="content_grid_tabla_boddy">
                        @foreach (var patrulla in Patrullas)
                        {
                            <div class="col_grid">
                                <p class="txt_plano">@patrulla.IdPatrulla</p>
                            </div>
                            <div class="col_grid">
                                <p class="txt_plano">@patrulla.Placa</p>
                            </div>
                            <div class="col_grid">
                                <p class="txt_plano">@patrulla.NumeroEconomico</p>
                            </div>
                            <div class="col_grid">
                                <div class="content_flex">
                                    @*<button class="btn_edit" @onclick="(() => IrEditarPatrulla(patrulla.IdPatrulla))">
                                        <i class="far fa-edit"></i>
                                        <span>Editar</span>
                                    </button>*@
                                    <button class="btn_delete" @onclick="(() => EliminarPatrulla(patrulla.IdPatrulla))">
                                        <i class="far fa-trash-alt"></i>
                                        <span>Eliminar</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="content_paginado">
                        @foreach (int i in paginas)
                        {
                            <div class="pagina" @onclick="(() => CambiarPaginaActual(i))">
                                @if (i == paginaActual)
                                {
                                    <span class="selected">@i</span>
                                }
                                else
                                {
                                    <span>@i</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    @if (alerta != "")
                    {
                        <h2 class="no_data">No hay Patrullas</h2>
                    }
                    else
                    {
                        <div class="loader"></div>
                    }
                }
            }
            else
            {
                @if (alerta != "")
                {
                    <h2 class="no_data">No hay Patrullas</h2>
                }
                else
                {
                    <h2 class="no_data">@alerta</h2>
                }
            }
        }
        else
        {
            <div class="loader"></div>
        }
    </div>
</div>